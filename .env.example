# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/financial_agent
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# "ollama" for local dev, "openai" for demo/fallback
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=dev-secret-key-change-in-prod

# ─── Agent ────────────────────────────────────────────────────────────────────
AGENT_MAX_STEPS=10
AGENT_TOOL_TIMEOUT_SECONDS=30
AGENT_TASK_TIMEOUT_SECONDS=300

# ─── Redis (Phase 4) ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
