# ── .env.cloud.example ─────────────────────────────────────────────────────────
# Copy this to .env on Railway (paste each variable into the Railway Variables tab).
# Never commit the filled-in version — it contains real secrets.

# ── Database — Neon (https://neon.tech) ──────────────────────────────────────
# Copy the "Connection string" from Neon dashboard → your project → Connection Details
# It looks like: postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/financial_agent?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/financial_agent?sslmode=require

# ── Redis — Upstash (https://console.upstash.com) ────────────────────────────
# Copy the "Redis URL" from Upstash dashboard → your database → Details
# It looks like: rediss://default:xxx@xxx.upstash.io:6379
REDIS_URL=rediss://default:your-token@your-db.upstash.io:6379

# ── LLM — Groq (https://console.groq.com) ────────────────────────────────────
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── API ───────────────────────────────────────────────────────────────────────
# Change this to a strong random secret in production
API_KEY=fca_change_me_to_a_strong_random_secret

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT_MAX_STEPS=8

# ── CORS (set to your Vercel frontend URL after deploying) ───────────────────
# Example: https://financial-agent.vercel.app
CORS_ORIGINS=https://your-app.vercel.app

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
LOG_FORMAT=json
